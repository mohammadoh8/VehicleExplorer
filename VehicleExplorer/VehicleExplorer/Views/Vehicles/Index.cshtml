@{
    ViewData["Title"] = "Vehicles";
}

<div class="py-4">
    <div class="mb-4">
        <h1 class="h3 mb-1">Vehicle Explorer</h1>
        <p class="text-muted mb-0">Select a make, model year, and vehicle type to view matching models.</p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-lg-5">
                    <label class="form-label fw-semibold" for="makeDropdownInput">Make</label>
                    <div id="makeDropdown"></div>
                </div>

                <div class="col-12 col-sm-4 col-lg-2">
                    <label class="form-label fw-semibold" for="modelYear">Year</label>
                    <input id="modelYear" class="form-control" type="number" min="1900" max="2030" value="2007" />
                </div>

                <div class="col-12 col-sm-8 col-lg-3">
                    <label class="form-label fw-semibold" for="typeDropdownInput">Vehicle type</label>
                    <div id="typeDropdown"></div>
                </div>

                <div class="col-12 col-lg-2 d-grid">
                    <button id="searchModelsButton" class="btn btn-primary" type="button">
                        Search models
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="message" class="alert d-none" role="status"></div>

    <div class="d-flex flex-column flex-md-row gap-2 align-items-md-center justify-content-between mb-2">
        <div>
            <h2 class="h5 mb-0">Models</h2>
            <span id="modelCount" class="text-muted small"></span>
        </div>
        <div class="input-group input-group-sm w-auto">
            <span class="input-group-text">Search</span>
            <input id="modelSearchInput" class="form-control" type="search" placeholder="Filter models" disabled />
        </div>
    </div>

    <div id="modelsList" class="list-group"></div>
    <nav class="mt-3" aria-label="Models pagination">
        <ul id="modelsPagination" class="pagination pagination-sm mb-0"></ul>
    </nav>
</div>
